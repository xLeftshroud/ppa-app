# ── PPA Backend Environment Configuration ──
# Copy this file to .env and customize as needed.
# All values below are defaults — uncomment and change to override.

# Path to the trained ML pipeline (joblib file), relative to backend/
# MODEL_PATH=artifacts/pipeline.joblib

# Path to the model metadata JSON, relative to backend/
# METADATA_PATH=artifacts/metadata.json

# Path to the training dataset CSV (used for per-SKU price quantiles), relative to backend/
# TRAINING_DATA_PATH=artifacts/dataset.csv

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Default chat provider. Supported values: openai, ollama
# LLM_PROVIDER=openai

# OpenAI chat configuration
# OPENAI_API_KEY=your_key
# OPENAI_MODEL=gpt-5.4-mini

# Ollama chat configuration
# Use http://host.docker.internal:11434/v1 when the backend runs in Docker and Ollama runs on the host machine.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=your_local_model           #gemma4, qwen3.5:9b
# OLLAMA_API_KEY=ollama
